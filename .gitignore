# Evaluation run output is NOT source controlled — may contain provider keys,
# prompts, responses, and absolute paths.
.amplifier/evaluation/
.ai/          # per-source convergence assessments and run artifacts
runs/
wiki/        # generated wiki output from pipeline runs
*.log

# uv.lock is intentionally NOT committed: wiki-weaver tracks @main of its runtime
# deps (amplifier-foundation, amplifier-unified-llm-client) so they stay in
# lockstep with the user's Amplifier ecosystem. Committing a lock file would
# silently freeze those deps at stale commits for every `uv sync` user.
# Use `wiki-weaver update` to refresh to latest @main.
uv.lock

# OS/environment files (must stay untracked)
.DS_Store
._*
.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
*.egg-info/
dist/
build/
