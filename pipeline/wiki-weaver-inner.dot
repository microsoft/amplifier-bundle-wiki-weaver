// wiki-weaver-inner.dot -- Integrate ONE source into the wiki, until coherent.
//
// The inner attractor loop: ingest -> validate (structural, code) -> assess
// (quality, LLM, against the shared rubric) -> converged? -> (refine) feedback
// -> loop_restart. Specialized clone of convergence-factory.dot.
//
// This is the THINNEST provable slice. The outer corpus-sweep (foreach source)
// wraps this as a folder sub-pipeline once this is proven on real sources.
//
// Required context variables (inject via parent context.* or --context):
//   $source_path   -- the raw source article to integrate this cycle
//   $wiki_dir      -- the wiki directory (persistent artifact, survives loop_restart)
//   $schema_path   -- path to SCHEMA.md (the page contract)
//   $rubric_path   -- path to the eval rubric.md (assess uses Tier-2 criteria)
//   $validate_cmd  -- structural validator command (validate_wiki.py $wiki_dir)
//   $max_cycles    -- hard iteration bound (LLM-judged loops MUST be bounded)
//
// State lives on the FILESYSTEM ($wiki_dir, .ai/feedback/, .ai/assessment.md)
// because loop_restart resets context.

digraph wiki_weaver_inner {
    graph [
        goal="Integrate one source into a coherent, link-valid, contradiction-flagging wiki",
        default_max_retry="4",
        default_fidelity="compact"
    ]

    start [shape=Mdiamond, label="Start"]

    // INGEST (LLM): read source + existing wiki + prior feedback + schema,
    // then create/update concept/entity pages with [[links]], frontmatter,
    // and surface contradictions per the schema. Updates existing pages,
    // never creates per-source duplicates.
    ingest [
        label="Ingest Source",
        prompt="You are weaving one source into a persistent knowledge wiki.\n\nSource to integrate: $source_path\nWiki directory: $wiki_dir\nSchema (the page contract you MUST follow): $schema_path\n\nThis source has ALREADY been assigned a stable source id by the orchestrator: $source_id. Use EXACTLY this integer in every page's frontmatter `sources:` list for claims drawn from this source. Do NOT invent, guess, or renumber source ids.\n\nHARD PROHIBITION (process state is owned by the deterministic CLI, never by you): You MUST NOT create, write, append to, move, or delete `.processed.jsonl` (the ledger) or anything under `_archive/`. Archiving the source and appending the ledger line are the CLI's EXCLUSIVE job and happen ONLY after this pipeline reports real convergence. Do not fabricate run metadata (logs_dir, timestamps, converged flags). If you write or move those paths the run is treated as tampered and FAILS. Your job is ONLY to write/update wiki pages under $wiki_dir.\n\nFirst read $schema_path. Then read the CURRENT state of $wiki_dir (every existing page) and check .ai/feedback/ for refinement guidance from prior iterations.\n\nThen integrate the source:\n- Update EXISTING pages when the source discusses a concept already present (one page per concept; never create a near-duplicate).\n- Create new concept/entity pages for genuinely new concepts, with valid frontmatter (title, type, sources, last_updated).\n- Add [[wikilinks]] between related pages; every link must resolve to a page (create a stub if needed).\n- When the source DISAGREES with an existing page (different claim, or a different number for the same fact), DO NOT average or overwrite -- add/extend an '## Open tensions' section citing both sides with sources.\n- Maintain index.md and overview.md.\n\nWrite all changes under $wiki_dir now.\n\nWhen you have finished writing, your FINAL message MUST be a short one-paragraph summary listing the pages you created or updated. Do not end with an empty message."
    ]

    // VALIDATE (code, deterministic): the Tier-1 structural graders.
    // Non-zero exit (broken links / missing frontmatter / orphans) forces the
    // loop back into the refine cycle via the validate -[fail]-> feedback edge
    // below, instead of dead-ending at no_matching_edge. A FAILED tool node only
    // traverses edges that match condition="outcome=fail" (engine fail-fast
    // rule), so both outcomes are routed EXPLICITLY.
    validate [
        shape=parallelogram,
        label="Validate Structure",
        tool_command="$validate_cmd"
    ]

    // ASSESS (LLM): judge against the shared rubric Tier-2. MUST set
    // preferred_label=converged or =refine.
    assess [
        label="Assess Quality",
        prompt="You are assessing whether the wiki at $wiki_dir has correctly integrated the source $source_path.\n\nApply the Tier-2 quality rubric in $rubric_path: synthesis (merged, not dumped), contradiction-handling (tensions surfaced not averaged), merge-correctness (distinct gaps kept distinct), no-confabulation (no claims absent from sources; no strawman asserted), provenance-fidelity.\n\nReview the structural validation results and the wiki pages touched.\n\nFirst write a brief assessment (per-dimension score + evidence) to .ai/assessment.md.\n\nThen DECIDE: if every rubric dimension is >= 4/5 the wiki has converged for this source; otherwise it needs another refine cycle.\n\nYour FINAL message MUST be exactly one JSON object and NOTHING else (no prose, no code fence). It routes the pipeline:\n  - converged: {\"status\": \"success\", \"preferred_label\": \"converged\", \"notes\": \"<one line why>\"}\n  - refine:    {\"status\": \"success\", \"preferred_label\": \"refine\", \"notes\": \"<one line gap>\"}\nThe value of preferred_label MUST be exactly 'converged' or 'refine'."
    ]

    check [shape=diamond, label="Converged?"]

    // FEEDBACK (LLM): only on refine. Targeted guidance for next cycle.
    feedback [
        label="Write Feedback",
        prompt="Write targeted refinement guidance for the next ingest cycle.\n\nRead .ai/assessment.md and any prior files in .ai/feedback/.\nWrite a new file to .ai/feedback/ using the Pyramid Summary pattern:\n  1. Key finding (1 sentence) -- the most important gap.\n  2. What to change (3-5 specific, actionable bullets) -- e.g. which pages to merge, which tension to surface, which broken link to fix.\n  3. Why it matters (1-2 sentences) -- how it moves toward a coherent wiki.\nFocus only on the delta needed to converge.\n\nAfter writing the feedback file, your FINAL message MUST be a one-line confirmation naming the feedback file you wrote. Do not end with an empty message."
    ]

    done [shape=Msquare, label="Done"]

    start -> ingest
    ingest -> validate

    // VALIDATE routes BOTH outcomes explicitly. A tool node that exits non-zero
    // produces outcome=fail; the engine's fail-fast rule means it will ONLY
    // traverse an edge whose condition matches outcome=fail. Without the second
    // edge a structural failure dead-ends at no_matching_edge (the old defect:
    // one dangling link halted every future ingest). On fail we drop into the
    // refine loop at `feedback` so the broken-link/error output is turned into
    // guidance and repaired on the next ingest cycle.
    validate -> assess   [label="pass", condition="outcome=success"]
    validate -> feedback [label="fail", condition="outcome=fail"]

    assess -> check

    check -> done     [label="converged", condition="context.preferred_label=converged"]
    check -> feedback [label="refine",    condition="context.preferred_label=refine"]

    feedback -> ingest [loop_restart="true"]
}
