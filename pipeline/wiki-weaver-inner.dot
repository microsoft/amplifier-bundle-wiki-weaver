// wiki-weaver-inner.dot -- Integrate ONE source into the wiki, until coherent.
//
// The inner attractor loop: ingest -> validate (structural, code) -> assess
// (quality, LLM, against the shared rubric) -> converged? -> (refine) feedback
// -> loop_restart. Specialized clone of convergence-factory.dot.
//
// This is the THINNEST provable slice. The outer corpus-sweep (foreach source)
// wraps this as a folder sub-pipeline once this is proven on real sources.
//
// Required context variables (inject via parent context.* or --context):
//   $source_path   -- the raw source article to integrate this cycle
//   $wiki_dir      -- the wiki directory (persistent artifact, survives loop_restart)
//   $schema_path   -- path to SCHEMA.md (the page contract)
//   $convergence_rubric -- path to CONVERGENCE_RUBRIC.md (assess's per-SOURCE
//                          gate: "is THIS one source well integrated?" -- NOT the
//                          whole-corpus eval rubric, which votes refine forever on
//                          a single freshly-ingested article)
//   $validate_cmd  -- structural validator command (validate_wiki.py $wiki_dir)
//   $max_cycles    -- hard iteration bound (LLM-judged loops MUST be bounded)
//
// State lives on the FILESYSTEM ($wiki_dir, .ai/feedback/, .ai/assessment.md)
// because loop_restart resets context.

digraph wiki_weaver_inner {
    graph [
        goal="Integrate one source into a coherent, link-valid, contradiction-flagging wiki",
        default_max_retry="4",
        default_fidelity="compact"
    ]

    start [shape=Mdiamond, label="Start"]

    // INGEST (LLM): read source + existing wiki + prior feedback + schema,
    // then create/update concept/entity pages with [[links]], frontmatter,
    // and surface contradictions per the schema. Updates existing pages,
    // never creates per-source duplicates.
    ingest [
        label="Ingest Source",
        goal_gate=true,
        retry_target="ingest",
        prompt="You are weaving one source into a persistent knowledge wiki.\n\nSource to integrate: $source_path\nWiki directory: $wiki_dir\nSchema (the page contract you MUST follow): $schema_path\n\nThis source has ALREADY been assigned a stable source id by the orchestrator: $source_id. Use EXACTLY this integer in every page's frontmatter `sources:` list for claims drawn from this source. Do NOT invent, guess, or renumber source ids.\n\nHARD PROHIBITION (process state is owned by the deterministic CLI, never by you): You MUST NOT create, write, append to, move, or delete `.processed.jsonl` (the ledger) or anything under `_archive/`. Archiving the source and appending the ledger line are the CLI's EXCLUSIVE job and happen ONLY after this pipeline reports real convergence. Do not fabricate run metadata (logs_dir, timestamps, converged flags). If you write or move those paths the run is treated as tampered and FAILS. Your job is ONLY to write/update wiki pages under $wiki_dir.\n\nFirst read $schema_path.\n\nREMEDIATION COMES FIRST: read $validation_report (the deterministic validator's latest result). If it exists and says FAIL, your #1 job THIS cycle is to fix EVERY listed failure -- each broken [[wikilink]], orphan page, missing/invalid-frontmatter page, and uncited page named there -- before any other work. Do not stop until each listed item is resolved.\n\nThen check .ai/feedback/ for refinement guidance from prior iterations.\n\nWork from a FOCUSED slice of the wiki, not the whole corpus (this must scale): read index.md and overview.md, the existing pages whose concepts THIS source touches (find them by title/topic), and every page named in $validation_report. Do NOT read every page in the wiki each cycle.\n\nThen integrate the source:\n- INTEGRATE EXISTING pages when the source adds to a concept already present (one page per concept; never create a near-duplicate): RE-READ the affected section(s) in full and RE-WRITE them so this source's claims are FUSED with existing claims at the sentence and paragraph level -- do NOT merely append new sentences or paragraphs that stand alone citing only this source; synthesize them INTO the existing prose. Sections MUST be organized by THEME, not by source. NEVER create a header of the form '## Topic (from Source N)', '## Topic (Source N)', or '## Source N: ...'. NEVER write consecutive paragraphs within a thematic section where each cites a single disjoint source -- if a paragraph citing only [2] is followed by a paragraph citing only [3], MERGE them: state the shared point once citing [2][3] and integrate the differences in the same breath. TARGET: a reader cannot tell how many sources a section drew from without reading the inline [N] markers; most cited sentences on a multi-source page should weave two or more sources, not form single-source runs. EXAMPLE -- STACKED (bad): 'Claude Code runs in the terminal [2]. It supports subagents [3]. It can do cross-language migration [3].' WOVEN (good): 'Claude Code is a terminal-native agent [2][3] whose subagent model [3] enables multi-step work like cross-language migrations [3], distinguishing it from editor-bound tools [2].' When two sources cover the same point, merge into one statement citing both [N][M]; when they disagree, use '## Open tensions' (see below) -- do not give each its own section.\n- Create new concept/entity pages for genuinely new concepts, with valid frontmatter (title, type, sources, last_updated).\n- CITE-OR-DON'T-CLAIM: every non-trivial claim MUST trace to THIS source ($source_id) or an existing page. If you cannot ground a claim, do NOT assert it -- write a '> TODO-VERIFY: <the unverified statement>' blockquote instead. A TODO-VERIFY is PREFERRED over speculation; never invent facts to fill a gap.\n- FRAME-VENDOR-CLAIMS: vendor/marketing/promotional or superlative performance claims (e.g. 'production-ready in one attempt', '10x faster', star counts or adoption stats reported by the vendor) MUST be attributed in the wiki's voice ('X reports...', 'according to [N]...', 'claims to be...') not asserted as established fact. Distinguish vendor assertion from independently verified fact.\n- NO DANGLING LINKS: every [[wikilink]] must resolve to a real page. Either create a SUBSTANTIVE page for the target (see next rule) or do not add the link.\n- NO EMPTY STUBS: a page must contain at least one real, grounded sentence of content -- never a title-and-frontmatter-only shell. If you cannot say something real and sourced about a concept, do not create its page (and therefore do not link to it).\n- CONTRADICTIONS GO IN '## Open tensions' (surface, don't average): when the source DISAGREES with an existing page (different claim, or a different number for the same fact), DO NOT average or overwrite -- add/extend an '## Open tensions' section citing both sides with sources.\n- Maintain index.md and overview.md.\n\nWrite all changes under $wiki_dir now.\n\nWhen you have finished writing, your FINAL message MUST be a short one-paragraph summary listing the pages you created or updated and (when you were repairing validator failures) how you resolved each listed item. NEVER end the turn with only tool calls or an empty message -- if your most recent action was a tool call, emit your summary now as plain text before stopping."
    ]

    // VALIDATE (code, deterministic): the Tier-1 structural graders.
    // Non-zero exit (broken links / missing frontmatter / orphans) forces the
    // loop back into the refine cycle via the validate -[fail]-> feedback edge
    // below, instead of dead-ending at no_matching_edge. A FAILED tool node only
    // traverses edges that match condition="outcome=fail" (engine fail-fast
    // rule), so both outcomes are routed EXPLICITLY.
    validate [
        shape=parallelogram,
        label="Validate Structure",
        tool_command="$validate_cmd"
    ]

    // ASSESS (LLM): judge ONE source's integration against the PER-SOURCE
    // convergence rubric (NOT the whole-corpus eval rubric, which votes refine
    // forever on a single freshly-ingested article). MUST set
    // preferred_label=converged or =refine.
    assess [
        label="Assess Quality",
        goal_gate=true,
        retry_target="assess",
        prompt="You are assessing ONE question: has THIS single source -- $source_path (assigned id $source_id) -- been well integrated into the wiki at $wiki_dir?\n\nThis is a PER-SOURCE convergence gate, NOT a whole-corpus completeness grade. Judge ONLY the delta this source contributed and the pages it touched. Do NOT require other corpus sources to be present, do NOT demand whole-wiki completeness, and do NOT penalize the wiki for concepts THIS source never discussed. A small, honest, well-merged single-source contribution IS converged.\n\nApply the per-source rubric in $convergence_rubric, scoring each dimension 1-5 for THIS source only:\n  C1 synthesis -- the source was merged and pre-digested into the right concept pages, not dumped or concatenated as a raw blob.\n  C2 merge-correctness -- shared concepts updated EXISTING pages in place (one page per concept; no near-duplicate created).\n  C3 contradiction-handling -- genuine conflicts (with an existing page, or within the source) surfaced in an '## Open tensions' section citing BOTH sides, never averaged or overwritten.\n  C4 no-confabulation -- every non-trivial claim traces to THIS source or an existing page. A '> TODO-VERIFY:' blockquote for an ungrounded claim is the CORRECT, PREFERRED move and is NOT a failure; only invented facts or asserted strawman framings fail this dimension.\n  C5 provenance -- pages carrying this source's claims cite $source_id in their frontmatter.\n\nDo NOT re-litigate structural mechanics (link resolution, frontmatter, orphans). The deterministic validate node already gated those; if you reached this step, structure passed. Focus on integration QUALITY for THIS source.\n\nFirst write a brief assessment (per-dimension C1-C5 score + one-line evidence each) to .ai/assessment.md.\n\nThen DECIDE: if every dimension C1-C5 is >= 4/5 for THIS source, it has converged; otherwise it needs another refine cycle.\n\nYour FINAL message MUST be exactly one JSON object and NOTHING else (no prose, no code fence). It routes the pipeline:\n  - converged: {\"status\": \"success\", \"preferred_label\": \"converged\", \"notes\": \"<one line why>\"}\n  - refine:    {\"status\": \"success\", \"preferred_label\": \"refine\", \"notes\": \"<one line gap>\"}\nThe value of preferred_label MUST be exactly 'converged' or 'refine'.\n\nFINAL-MESSAGE CONTRACT (this is the rule that ROUTES the pipeline -- treat it as the single most important instruction): your VERY LAST message this turn MUST be exactly that one-line JSON object and NOTHING ELSE -- no prose before or after, no markdown, no code fence, no commentary. Writing .ai/assessment.md is a tool call, not your verdict. After you finish writing it -- or after ANY other tool call -- your most recent action will have been a tool call, so you MUST THEN emit the one-line JSON verdict as a fresh final message. Do NOT end the turn on a tool call, on a summary sentence, or on an empty message. If you are about to reply with prose, replace that prose with the JSON. A missing, prose, or fenced verdict mis-routes the pipeline and FALSELY reports non-convergence even when the wiki is clean."
    ]

    // CHECK routes EXHAUSTIVELY (no dead-end). The engine's select_edge tries
    // conditional edges FIRST (Step 1); only if none match does it fall through
    // to the single UNCONDITIONAL edge (Step 4). So `done` is reachable ONLY via
    // its explicit converged condition, while EVERYTHING ELSE -- refine, an unset
    // preferred_label=None (the empty-spawn flake degrades assess to PROSE and
    // _parse_outcome yields SUCCESS+label=None), prose, or any unrecognized label
    // -- falls through to the unconditional `check -> feedback` fallback and the
    // refine loop. The fail-safe direction is MORE work, never premature done.
    check [shape=diamond, label="Converged?"]

    // FEEDBACK (LLM): only on refine. Targeted guidance for next cycle.
    feedback [
        label="Write Feedback",
        prompt="Write targeted refinement guidance for the next ingest cycle.\n\nREAD THE DETERMINISTIC VALIDATOR FIRST: read $validation_report. If it says FAIL, that result -- NOT any quality assessment -- is your primary input. Your #1 job is remediation guidance that fixes EACH listed failure verbatim: name every broken [[wikilink]], orphan page, missing/invalid-frontmatter page, and uncited page it lists, and say concretely how the next ingest cycle must resolve each one (create the missing target page with real grounded content, add an inbound link, add frontmatter/sources, etc.). Do NOT treat the wiki as converged while $validation_report shows FAIL, regardless of what any assessment claims.\n\nThen read .ai/assessment.md and any prior files in .ai/feedback/ for secondary quality context only.\nWrite a new file to .ai/feedback/ using the Pyramid Summary pattern:\n  1. Key finding (1 sentence) -- the most important gap (lead with the validator failure if there is one).\n  2. What to change (3-5 specific, actionable bullets) -- EACH listed validator failure FIRST (which broken link to fix, which orphan to link, which page to cite), then any quality deltas.\n  3. Why it matters (1-2 sentences) -- how it moves toward a coherent, link-valid wiki.\nFocus only on the delta needed to converge.\n\nAfter writing the feedback file, your FINAL message MUST be a one-line confirmation naming the feedback file you wrote. Do not end with an empty message."
    ]

    done [shape=Msquare, label="Done"]

    start -> ingest
    ingest -> validate

    // VALIDATE routes BOTH outcomes explicitly. A tool node that exits non-zero
    // produces outcome=fail; the engine's fail-fast rule means it will ONLY
    // traverse an edge whose condition matches outcome=fail. Without the second
    // edge a structural failure dead-ends at no_matching_edge (the old defect:
    // one dangling link halted every future ingest). On fail we drop into the
    // refine loop at `feedback` so the broken-link/error output is turned into
    // guidance and repaired on the next ingest cycle.
    validate -> assess   [label="pass", condition="outcome=success"]
    validate -> feedback [label="fail", condition="outcome=fail"]

    assess -> check

    check -> done     [label="converged", condition="context.preferred_label=converged"]
    check -> feedback [label="refine",    condition="context.preferred_label=refine"]
    // ELSE (unconditional fallback): the ONLY unconditional edge out of `check`,
    // so the engine's Step-4 lexical-tiebreak gotcha cannot bite. Catches None /
    // prose / any non-converged label -> refine loop instead of no_matching_edge.
    check -> feedback [label="else (unset/unknown -> refine)"]

    feedback -> ingest [loop_restart="true"]
}
